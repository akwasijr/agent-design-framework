    {
      "id": 19,
      "type": "section",
      "title": "Apply Five Design Principles",
      "subtitle": "Design Principles",
      "body": "The foundation for every agent-managed product"
    },
    {
      "id": 20,
      "type": "statement",
      "title": "Show Outcomes, Not Processes",
      "body": "Humans care about results. Process details on demand only.",
      "contrast": {
        "wrong": "Processed record 4,532 of 12,000",
        "right": "Portfolio rebalanced. Savings: $45K."
      }
    },
    {
      "id": 21,
      "type": "statement",
      "title": "Surface Exceptions, Hide Routine",
      "body": "Human attention is the scarcest resource. Only interrupt when it genuinely matters.",
      "contrast": {
        "wrong": "Everything dashboard showing all actions",
        "right": "47 processed normally. 2 need you."
      }
    },
    {
      "id": 22,
      "type": "statement",
      "title": "Earn Trust Through Demonstrated Competence",
      "body": "Trust is built incrementally — not toggled on.",
      "stages": ["Supervised", "Guided", "Collaborative", "Trusted"]
    },
    {
      "id": 23,
      "type": "statement",
      "title": "Express Values, Not Settings",
      "body": "Humans speak intent. Systems translate to parameters.",
      "contrast": {
        "wrong": "risk_score_threshold: 0.65",
        "right": "Be conservative. When unsure, ask."
      }
    },
    {
      "id": 24,
      "type": "statement",
      "title": "Make Agent Creation Accessible",
      "body": "As natural as making a spreadsheet. Domain expertise over code.",
      "steps": ["Start with intent", "Define work", "Set boundaries", "Test & refine", "Deploy & evolve"]
